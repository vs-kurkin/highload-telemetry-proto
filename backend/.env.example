# Django Settings
DEBUG=True
SECRET_KEY=django-insecure-highload-telemetry-prototype-key-2026
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_NAME=telemetry_db
DB_USER=telemetry_user
DB_PASSWORD=telemetry_pass
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# MQTT
MQTT_HOST=localhost
MQTT_PORT=1883

# Telemetry Logic
TELEMETRY_FLUSH_INTERVAL=5.0
TELEMETRY_HISTORY_LIMIT=20
ALERT_BATTERY_THRESHOLD=10.0
ALERT_THROTTLE_SECONDS=600
